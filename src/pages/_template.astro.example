---
// Custom subpage template.
//
// To use: copy this file to src/pages/<your-route>.astro
// (drop the .example suffix), edit the props below, write content in the
// <PageLayout> slot, and — if it should appear in nav — add an entry to the
// `items` array in src/components/Menu.astro.
//
// See STYLEGUIDE.md for tokens, type scale, and component reference.

import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout
  title="Page Title"
  eyebrow="Section"
  description="Short deck shown under the title and in social previews."
  heroImage="https://images.unsplash.com/photo-1500462918059-b1a0cb512f1d?auto=format&fit=crop&w=1600&q=70"
>
  <p>
    Body content goes here. Anything inside this slot is wrapped in the
    <code>.prose</code> styles (line-height, type scale, blockquote, code,
    etc.) — write plain markup or import components and they will inherit.
  </p>

  <h2>A section</h2>
  <p>Use headings, paragraphs, lists, blockquotes, code blocks freely.</p>

  <blockquote>
    Pull quote rendered in Playfair italic with a left border.
  </blockquote>
</PageLayout>
