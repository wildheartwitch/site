---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact"
  eyebrow="Say hello"
  description="Letters, pitches, and corrections all welcome. We read everything."
>
  <div class="prose">
    <p>
      Email us at <a href="mailto:hello@example.com">hello@example.com</a>, or use the form below.
      Replace the form action with your own endpoint (Formspree, Netlify Forms, etc.) before
      deploying.
    </p>
  </div>

  <form class="contact-form" action="mailto:hello@example.com" method="post" enctype="text/plain">
    <label>
      Name
      <input type="text" name="name" required />
    </label>
    <label>
      Email
      <input type="email" name="email" required />
    </label>
    <label>
      Message
      <textarea name="message" required></textarea>
    </label>
    <button type="submit">Send</button>
  </form>
</PageLayout>
