---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="contato"
  eyebrow="quer falar comigo?"
  description="propostas de trabalhos e parcerias, convites para eventos, sugestões e ideias são sempre bem-vindos. respondo assim que puder :)"
>
  <div class="prose">
    <p>
      mande um email para <a href="mailto:larafreitasdecarvalho@gmail.com">larafreitasdecarvalho@gmail.com</a>, ou use o formulário abaixo.
    </p>
  </div>

  <form class="contact-form" action="mailto:larafreitasdecarvalho@gmail.com" method="post" enctype="text/plain">
    <label>
      nome
      <input type="text" name="name" required />
    </label>
    <label>
      email
      <input type="email" name="email" required />
    </label>
    <label>
      escreva sua mensagem aqui
      <textarea name="message" required></textarea>
    </label>
    <button type="submit">enviar</button>
  </form>
</PageLayout>
