---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const items = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title="Selected Work"
  eyebrow="Portfolio"
  description="A sample of issues, collaborations, and side projects from the studio."
>
  {
    items.length === 0 ? (
      <p>
        No work entries yet. Add markdown files to <code>src/content/work/</code>
        with <code>title</code>, <code>year</code>, <code>cover</code>, and
        <code>summary</code> fields.
      </p>
    ) : (
      <div class="work-grid">
        {items.map((item) => {
          const Tag = item.data.url ? 'a' : 'div';
          return (
            <Tag
              class="work-item"
              href={item.data.url}
              target={item.data.url ? '_blank' : undefined}
              rel={item.data.url ? 'noopener' : undefined}
            >
              <img src={item.data.cover} alt="" loading="lazy" />
              <div class="work-item__year">{item.data.year}</div>
              <div class="work-item__title">{item.data.title}</div>
              <div class="work-item__summary">{item.data.summary}</div>
            </Tag>
          );
        })}
      </div>
    )
  }
</PageLayout>
