---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => +b.data.date - +a.data.date,
);

const fmt = (d: Date) =>
  `${String(d.getDate()).padStart(2, '0')}.${String(d.getMonth() + 1).padStart(2, '0')}.${d.getFullYear()}`;

const renderHeadline = (headline: string, emphasis?: string) => {
  if (!emphasis) return headline;
  return headline.replace('{emphasis}', `__${emphasis}__`);
};
---

<PageLayout
  title="The Blog"
  eyebrow="Journal"
  description="Essays, field notes, and longer reads from Self Esteem."
>
  <div class="post-list">
    {
      posts.map((post) => {
        const parts = renderHeadline(post.data.headline, post.data.emphasis).split('__');
        return (
          <a class="post-card" href={`/blog/${post.id}`}>
            <div class="post-card__cover">
              <img src={post.data.cover} alt="" loading="lazy" />
            </div>
            <div>
              <div class="post-card__meta">
                {fmt(post.data.date)} · {post.data.author} · {post.data.readTime}
              </div>
              <h2 class="post-card__title">
                {parts.map((part, i) => (i % 2 === 1 ? <span>{part}</span> : <>{part}</>))}
              </h2>
              <p class="post-card__excerpt">{post.data.excerpt}</p>
              {post.data.tags.length > 0 && (
                <div class="post-card__tags">
                  {post.data.tags.map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        );
      })
    }
  </div>
</PageLayout>
