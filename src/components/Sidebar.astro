---
import Marquee from './Marquee.astro';
import Circle from './Circle.astro';

interface Entry {
  data: {
    title: string;
    subtitle: string;
    date: Date;
    order: number;
  };
}

interface Props {
  entries: Entry[];
  heading?: string;
  seeAllHref?: string;
}

const { entries, heading = 'projetos', seeAllHref = '#' } = Astro.props;

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-GB', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  })
    .format(d)
    .replaceAll('/', '.');

const sorted = [...entries].sort((a, b) => a.data.order - b.data.order);
---

<div class="blog-part right-blog">
  <Marquee />
  <div class="blog-right-title-container">
    <div class="blog-right-title">{heading}</div>
    <a href={seeAllHref} class="blog-menu rounded">mais</a>
  </div>
  <div class="blog-right">
    {
      sorted.map((e) => (
        <div class="blog-right-container">
          <div class="blog-title-date">
            <div class="blog-right-page">{e.data.order}</div>
            <div class="date">{fmt(e.data.date)}</div>
          </div>
          <div class="blog-right-page-title">{e.data.title}</div>
          <div class="blog-right-page-subtitle">{e.data.subtitle}</div>
        </div>
      ))
    }
    <Circle />
  </div>
</div>
